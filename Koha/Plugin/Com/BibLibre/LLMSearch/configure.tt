[% USE KohaDates %]
[% INCLUDE 'doc-head-open.inc' %]
<title>LLMSearch Plugin Configuration</title>
[% INCLUDE 'doc-head-close.inc' %]
</head>
<body>
[% INCLUDE 'header.inc' %]
[% INCLUDE 'cat-search.inc' %]

<div id="breadcrumbs"><a href="/cgi-bin/koha/mainpage.pl">Home</a> &rsaquo; <a href="/cgi-bin/koha/plugins/plugins-home.pl">Plugins</a> &rsaquo; LLMSearch &rsaquo; Configuration</div>

<div id="doc3">
    <h3>LLMSearch: Configuration</h3>
    	<form method="get">
        <input type="hidden" name="class" value="[% CLASS %]"/>
        <input type="hidden" name="method" value="[% METHOD %]"/>
	[% INCLUDE 'csrf-token.inc' %]
	<div>
            <label for="api_key">LLM API Key</label>
	    <input type="text" name="api_key" value="[% api_key %]"/>
	</div>
	<div>
	    <label for="welcome">Welcome message</label>
	    <textarea name="welcome">[% welcome %]</textarea>
	</div>
	<details>
	    <summary style="cursor:pointer; font-weight:bold;">&#9881; Expert: Custom system prompt</summary>
	    <div>
	        <label for="debug_mode">Enable debug mode (logs all LLM exchanges to the browser console)</label>
	        <input type="checkbox" name="debug_mode" value="1" [% IF ( debug_mode ) %]checked="checked"[% END %]/>
	    </div>
	    <div class="hint" style="margin:.5em 0;">
	        <strong>Warning:</strong> this prompt controls the LLM's entire behaviour.
	        Modify only if you know what you are doing.<br/>
	        The placeholder <code>{{SEARCH_INDEXES}}</code> will be replaced at runtime with
	        the list of search indexes configured in Koha. Keep it in your prompt so the LLM
	        knows which fields are available.<br/>
	        Leave the textarea empty and save to reset to the built-in default prompt.
	    </div>
	    <div>
	        <label for="system_prompt">System Prompt</label><br/>
	        <textarea name="system_prompt" rows="20" cols="80">[% system_prompt %]</textarea>
	    </div>
	</details>
	<div>
            <label for="model">Model to use</label>
	    <input type="text" name="model" value="[% model %]"/>
	</div>
	<div>
	    <label for="base_url">Base URL</label>
	    <input type="text" name="base_url" value="[% base_url %]"/>
	</div>
	<div>
	    <label for="only_logged">Optional : Only show to logged-in users</label>
	    <input type="checkbox" name="only_logged" [% IF ( only_logged ) %]checked="checked"[% END %]/>
	</div>
	<div>
	    <label for="allowed_cat">Allowed category codes, separated with space</label>
	    <input type="text" name="allowed_cat" value="[% allowed_cat %]"/>
	</div>
	<div>
	    <label for="only_logged">Optional : Enable stats collection</label>
	    <input type="checkbox" name="enable_stats" [% IF ( enable_stats ) %]checked="checked"[% END %]/>
	</div>
	<div>
	    <label for="max_tool_rounds">Search validation : max tool call rounds</label>
	    <input type="number" name="max_tool_rounds" min="1" max="20" value="[% max_tool_rounds %]"/>
	    <p class="hint">Maximum number of catalog search rounds the LLM may perform to verify that suggested links return results. Function calling is always active (minimum 1). Requires a model that supports function calling / tools (e.g. mistral-small-latest, gpt-4o).</p>
	</div>
	<div>
            <input type="hidden" name="save" value="1" />
            <input type="submit" value="Save configuration" />
	</div>
	</form>
[% INCLUDE 'intranet-bottom.inc' %]
